DATABASE_URL=postgres://trigger:trigger@localhost:5432/trigger?sslmode=disable
JWT_SECRET=change-me-to-a-random-secret
ENCRYPTION_KEY=change-me-to-64-hex-chars-representing-32-bytes
COMMANDS_DIR=./commands
PORT=8080

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback
GOOGLE_HOSTED_DOMAIN=yourcompany.com
FRONTEND_URL=http://localhost:5173

# First-deploy only: seeds an admin account when the DB has no users.
# Set to the admin's real Google Workspace email.
ADMIN_EMAIL=
